# config/default.yaml.template
# 复制此文件为 default.yaml 并填入您的 API Key
# 注意：不要将包含 API Key 的配置文件提交到 Git

llm:
  provider: "deepseek"
  openai:
    api_key: ""
    model: "gpt-4o"
    temperature: 0.3
    max_tokens: 4096
  ollama:
    base_url: "http://localhost:11434"
    model: "llama3:70b"
    temperature: 0.3
  deepseek:
    api_key: ""  # 在这里填入您的 DeepSeek API Key
    model: "deepseek-chat"
    temperature: 0.3
    max_tokens: 4096
    base_url: "https://api.deepseek.com"

annotation:
  mode: "sidebar"
  detail_level: "detailed"
  style:
    font_family: "Microsoft YaHei"
    font_size: 12
    color: "#333333"
    background: "#FFFFCC"

app:
  language: "zh-CN"
  theme: "system"
  recent_files_limit: 10
  auto_save: true
